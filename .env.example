# ============================================
# Flask Core
# ============================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# مفتاح التطبيق (غيّره في الإنتاج - استخدم: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-use-a-random-64-char-hex-string

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://saas_user:saas_password@localhost:5432/saas_db

# ============================================
# Redis (للجلسات و Rate Limiting)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Super Admin الأول (يُنشأ بواسطة أمر init)
# ============================================
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword123!

# ============================================
# AI Providers (احتياطي الشات على مستوى المنصة)
# ============================================
# الخيارات: openai | anthropic | google_gemini | mistral
AI_PROVIDER=openai

OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GOOGLE_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# مهلة HTTP لاستدعاءات مزودي الذكاء (اتصال، قراءة) بالثواني — تمنع تعليق طلب الشات
AI_HTTP_CONNECT_TIMEOUT=10
AI_HTTP_READ_TIMEOUT=25

# ============================================
# WhatsApp (للمرحلة 7 - ليس الآن)
# ============================================
WHATSAPP_ENABLED=False
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ============================================
# Email (SMTP لإرسال إشعارات الاستفسارات)
# ============================================
MAIL_ENABLED=False
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
# ضع هنا إيميل التطبيق وكلمة مرور التطبيق (App Password) من Google
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-app-email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ============================================
# Site Info
# ============================================
SITE_URL=http://localhost:5000
SITE_NAME=منصة خدمة العملاء

# ============================================
# Session Config
# ============================================
SESSION_TYPE=filesystem          # filesystem للتطوير، redis للإنتاج

# ============================================
# Rate Limiting
# ============================================
RATELIMIT_STORAGE_URI=memory://  # memory للتطوير، redis://... للإنتاج
